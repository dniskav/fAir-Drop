{
  "name": "fairdrop",
  "packageManager": "bun@1",
  "version": "1.0.0",
  "description": "fAir Drop: P2P file sharing in the browser via WebRTC",
  "main": "server.js",
  "scripts": {
    "dev": "PORT=3003 node server.js & SERVER_PORT=3003 VITE_PORT=3002 vite",
    "build": "rm -rf public/app && vite build",
    "start": "NODE_ENV=production node server.js",
    "deploy": "npm run build && NODE_ENV=production node server.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx src || true",
    "lint:fix": "eslint --ext .ts,.tsx src --fix"
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.8",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
